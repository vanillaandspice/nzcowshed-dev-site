---
---
<section class="hero">
  <div class="hero__bg" style="background-image: url('/assets/brand/landscape.webp')"></div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__headline">Concrete that grips. Cows that move.</h1>
    <p class="hero__sub">We grind grooves into your existing concrete — cowsheds, yards, car parks, boat ramps. Done in a day. Guaranteed for life.</p>
    <div class="hero__actions">
      <a href="/contact" class="hero__btn hero__btn--primary">Get a Quote</a>
      <a href="/services" class="hero__btn hero__btn--ghost">See Services</a>
    </div>
    <div class="hero__trust" aria-label="Key facts">
      <div class="hero__trust-track">
        <span>✓ 100% lifetime guarantee</span>
        <span>✓ North Island specialists</span>
        <span>✓ Same-week quotes</span>
        <!-- duplicated for seamless loop on mobile -->
        <span aria-hidden="true">✓ 100% lifetime guarantee</span>
        <span aria-hidden="true">✓ North Island specialists</span>
        <span aria-hidden="true">✓ Same-week quotes</span>
      </div>
    </div>
    <img src="/assets/brand/cow.webp" alt="" aria-hidden="true" class="hero__cow" />
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 42vh;
    display: flex;
    align-items: flex-start;
    background: var(--deep-purple);
    overflow: visible;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    background: center/cover no-repeat;
    opacity: 0.25;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(37,2,89,0.85) 0%, rgba(37,2,89,0.4) 100%);
  }
  .hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 800px;
    padding: 2rem var(--space-grid-margin) 0;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero__headline {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 1.05;
    color: var(--concrete-white);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }
  .hero__sub {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 2.5vw, 1.375rem);
    line-height: 1.6;
    color: rgba(255,255,255,0.9);
    max-width: 55ch;
    margin: 0 auto 1.5rem;
  }
  .hero__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .hero__btn {
    position: relative;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius);
    transition: transform var(--duration-base) var(--easing-standard),
                box-shadow var(--duration-base) var(--easing-standard),
                background var(--duration-base) var(--easing-standard);
  }
  .hero__btn--primary {
    background: var(--safety-orange);
    color: var(--concrete-white);
    padding: 0.875rem 2.75rem 0.875rem 2.25rem;
  }
  .hero__btn--primary::after {
    content: '→';
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%) translateX(6px);
    opacity: 0;
    transition: transform var(--duration-base) var(--easing-standard),
                opacity var(--duration-base) var(--easing-standard);
    font-family: var(--font-body);
    font-weight: 700;
  }
  .hero__btn--primary:hover {
    background: #f08030;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(236,121,38,0.55);
  }
  .hero__btn--primary:hover::after {
    transform: translateY(-50%) translateX(0);
    opacity: 1;
  }
  .hero__btn--ghost {
    background: transparent;
    color: var(--concrete-white);
    border: 2px solid rgba(255,255,255,0.6);
    padding: 0.875rem 2.25rem;
  }
  .hero__btn--ghost:hover {
    background: rgba(255,255,255,0.1);
    border-color: var(--concrete-white);
    transform: translateY(-2px);
  }
  .hero__trust {
    display: flex;
    justify-content: center;
    margin-bottom: 0;
    overflow: hidden;
    /* fade edges */
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
  }
  .hero__trust-track {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero__trust-track span {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--teal);
    font-weight: 600;
    white-space: nowrap;
  }
  /* Hide duplicate spans on desktop */
  .hero__trust-track span:nth-child(n+4) { display: none; }

  @media (max-width: 600px) {
    .hero__trust-track {
      flex-wrap: nowrap;
      animation: trustTicker 14s linear infinite;
    }
    /* Show duplicates for seamless loop on mobile */
    .hero__trust-track span:nth-child(n+4) { display: inline; }
    @keyframes trustTicker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
  }
  @media (max-width: 600px) and (prefers-reduced-motion: reduce) {
    .hero__trust-track { animation: none; flex-wrap: wrap; }
    .hero__trust-track span:nth-child(n+4) { display: none; }
    .hero__trust { mask-image: none; -webkit-mask-image: none; }
  }
  .hero__cow {
    width: clamp(140px, 18vw, 220px);
    height: auto;
    margin-top: 1rem;
    margin-bottom: -2rem;
    filter: drop-shadow(0 6px 16px rgba(0,0,0,0.5));
  }
</style>
