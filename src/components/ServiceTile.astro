---
interface Props {
  title: string;
  blurb: string;
  href: string;
  photo: string;
}
const { title, blurb, href, photo } = Astro.props;
---
<a href={href} class="service-tile reveal">
  <div class="service-tile__img" style={`background-image: url(${photo})`}></div>
  <div class="service-tile__body">
    <h3 class="service-tile__title">{title}</h3>
    <p class="service-tile__blurb">{blurb}</p>
    <span class="service-tile__cta">Learn more →</span>
  </div>
</a>

<style>
  .service-tile {
    display: flex;
    flex-direction: column;
    background: var(--concrete-white);
    border-top: var(--border-card-top);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: transform 0.3s var(--easing-standard),
                box-shadow 0.3s var(--easing-standard);
    will-change: transform;
  }
  .service-tile:hover {
    transform: translateY(-5px);
    box-shadow: 0 14px 36px rgba(59, 31, 110, 0.16);
  }
  .service-tile__img {
    aspect-ratio: 4/3;
    background: #000 center/cover no-repeat;
    overflow: hidden;
    transition: transform 0.45s var(--easing-standard);
  }
  .service-tile:hover .service-tile__img {
    transform: scale(1.06);
  }
  .service-tile__body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .service-tile__title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    letter-spacing: 0.02em;
    color: var(--deep-purple);
    margin: 0 0 0.75rem;
  }
  .service-tile__blurb {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: var(--leading-body-md);
    color: var(--on-surface-variant);
    margin: 0 0 1rem;
    flex: 1;
  }
  .service-tile__cta {
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.05em;
    color: var(--teal);
    text-transform: uppercase;
  }
</style>
