---
const year = new Date().getFullYear();
---
<footer class="site-footer">

  <!-- Navigation & contact -->
  <div class="site-footer__inner">

    <!-- Text logo centred full-width above the nav columns -->
    <div class="site-footer__logo">
      <span class="site-footer__logo-line1">NZ Cowshed</span>
      <span class="site-footer__logo-line2">Groovers</span>
    </div>

    <div class="site-footer__brand">
      <p>Concrete grooving across New Zealand.</p>
      <p class="site-footer__guarantee">100% lifetime guarantee for the lifespan of your concrete.</p>
    </div>
    <nav class="site-footer__nav" aria-label="Services">
      <h4>Services</h4>
      <ul>
        <li><a href="/concrete-grooving-services/cowshed-grooving">Cowshed Grooving</a></li>
        <li><a href="/concrete-grooving-services/yards">Yards</a></li>
        <li><a href="/concrete-grooving-services/car-parks">Car Parks</a></li>
        <li><a href="/concrete-grooving-services/boat-ramps-marine-docks">Boat Ramps</a></li>
      </ul>
    </nav>
    <nav class="site-footer__nav" aria-label="Company">
      <h4>Company</h4>
      <ul>
        <li><a href="/our-work">Our Work</a></li>
        <li><a href="/testimonials">Testimonials</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
    <div class="site-footer__contact">
      <h4>Get in touch</h4>
      <a href="tel:+6427474775" class="site-footer__phone">0274 747 775</a>
      <a href="mailto:info@cowshedgroovers.co.nz" class="site-footer__email">info@cowshedgroovers.co.nz</a>
      <p class="site-footer__area">North Island, New Zealand<br />Nationwide capability</p>
    </div>
    <!-- Cow mascot — visible on mobile only, sits right of nav columns -->
    <div class="site-footer__cow-wrap" aria-hidden="true">
      <img
        src="/assets/brand/cow-character.webp"
        alt=""
        class="site-footer__cow"
        loading="lazy"
        decoding="async"
        width="200"
        height="176"
      />
    </div>
  </div>

  <!-- Credits & copyright -->
  <div class="site-footer__base">
    <p class="site-footer__copyright">© {year} NZ Cowshed Groovers</p>
    <p class="site-footer__credits">
      Illustrations: <span>Scott Pearson</span>, Hamilton
      &thinsp;·&thinsp;
      Web: <span>Fast Web Guru</span>
      &thinsp;·&thinsp;
      AI and Systems Automation: <span>Vanilla &amp; Spice</span>
    </p>
  </div>

</footer>

<style>
  /* ── Structure ─────────────────────────────────────── */
  .site-footer {
    background: var(--primary, #1a0a2e);
    color: rgba(255,255,255,0.85);
  }

  /* ── Logo ───────────────────────────────────────────── */
  .site-footer__logo {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    padding-bottom: 1rem;
  }
  .site-footer__logo-line1 {
    font-family: var(--font-heading);
    color: var(--safety-orange);
    font-size: clamp(1.4rem, 3.5vw, 2.25rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .site-footer__logo-line2 {
    font-family: var(--font-heading);
    color: var(--concrete-white);
    font-size: clamp(1.85rem, 4.5vw, 3rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Inner nav grid ─────────────────────────────────── */
  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: var(--space-stack-lg);
    padding: 3rem var(--space-grid-margin) 3rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .site-footer__brand p {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.65);
    margin: 0 0 0.35rem;
  }
  .site-footer__guarantee {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--teal) !important;
  }
  .site-footer__nav h4,
  .site-footer__contact h4 {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal);
    margin: 0 0 0.75rem;
  }
  .site-footer__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .site-footer__nav a {
    font-family: var(--font-body);
    font-size: 0.9rem;
    text-decoration: none;
    color: rgba(255,255,255,0.65);
    transition: color 0.18s ease;
  }
  .site-footer__nav a:hover { color: var(--concrete-white); }
  .site-footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .site-footer__phone {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--safety-orange);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.18s ease;
  }
  .site-footer__phone:hover { color: #f87d3a; }
  .site-footer__email {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.18s ease;
  }
  .site-footer__email:hover { color: rgba(255,255,255,0.9); }
  .site-footer__area {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
    margin: 0.25rem 0 0;
  }

  /* Cow — hidden on desktop, shown on mobile beside nav columns */
  .site-footer__cow-wrap {
    display: none;
  }
  .site-footer__cow {
    width: 100%;
    max-width: 130px;
    height: auto;
    filter: drop-shadow(0 4px 10px rgba(0,0,0,0.3));
  }

  /* ── Base/credits bar ───────────────────────────────── */
  .site-footer__base {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 1.25rem var(--space-grid-margin);
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .site-footer__copyright {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: rgba(255,255,255,0.35);
    margin: 0;
  }
  .site-footer__credits {
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: rgba(255,255,255,0.25);
    margin: 0;
    letter-spacing: 0.02em;
  }
  .site-footer__credits span {
    color: rgba(255,255,255,0.4);
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 768px) {
    /* 2-column grid: nav row, then contact | cow */
    .site-footer__inner {
      grid-template-columns: 1fr 1fr;
      align-items: end;
    }
    .site-footer__brand { grid-column: 1 / -1; }
    .site-footer__contact { grid-column: 1; }
    .site-footer__cow-wrap {
      display: flex;
      align-items: flex-end;
      justify-content: center;
      grid-column: 2;
      grid-row: 4;
      padding-bottom: 0.25rem;
    }
    .site-footer__base {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
  @media (max-width: 480px) {
    .site-footer__cow { max-width: 100px; }
  }
  @media (max-width: 360px) {
    .site-footer__inner { grid-template-columns: 1fr 1fr; }
    .site-footer__cow-wrap { display: none; }
  }
</style>
