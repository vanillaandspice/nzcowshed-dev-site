---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="site-footer__banner">
    <a href="/">
      <img src="/assets/brand/banner-logo.webp" alt="NZ Cowshed Groovers" />
    </a>
  </div>
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <p>Concrete grooving across New Zealand.<br />100% lifetime guarantee on every groove.</p>
    </div>
    <nav class="site-footer__nav" aria-label="Footer navigation">
      <h4>Services</h4>
      <ul>
        <li><a href="/services/cowshed-grooving">Cowshed Grooving</a></li>
        <li><a href="/yards">Yards</a></li>
        <li><a href="/car-parks">Car Parks</a></li>
        <li><a href="/boat-ramps-marine-docks">Boat Ramps</a></li>
      </ul>
    </nav>
    <nav class="site-footer__nav" aria-label="Company navigation">
      <h4>Company</h4>
      <ul>
        <li><a href="/our-work">Our Work</a></li>
        <li><a href="/testimonials">Testimonials</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
    <div class="site-footer__contact">
      <h4>Get in touch</h4>
      <a href="tel:+6427474775" class="site-footer__phone">0274 747 775</a>
      <a href="mailto:info@cowshedgroovers.co.nz">info@cowshedgroovers.co.nz</a>
      <p class="site-footer__area">North Island, New Zealand<br />Nationwide capability</p>
    </div>
  </div>
  <div class="site-footer__base">
    <p>© {year} NZ Cowshed Groovers. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--primary);
    color: rgba(255,255,255,0.85);
    padding: 0 0 0;
  }
  .site-footer__banner {
    background: var(--deep-purple);
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 2.5rem var(--space-grid-margin);
    text-align: center;
  }
  .site-footer__banner img {
    max-width: min(700px, 90vw);
    width: 100%;
    height: auto;
    display: inline-block;
  }
  .site-footer__inner {
    padding-top: 3rem;
  }
  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: var(--space-stack-lg);
    padding: 0 var(--space-grid-margin) 3rem;
  }
  .site-footer__brand p { font-size: 0.9rem; line-height: 1.6; color: rgba(255,255,255,0.65); }
  .site-footer__nav h4, .site-footer__contact h4 {
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: var(--tracking-label-caps);
    color: var(--teal);
    margin: 0 0 0.75rem;
  }
  .site-footer__nav ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .site-footer__nav a { font-size: 0.9rem; text-decoration: none; color: rgba(255,255,255,0.7); }
  .site-footer__nav a:hover { color: var(--concrete-white); }
  .site-footer__contact { display: flex; flex-direction: column; gap: 0.5rem; }
  .site-footer__phone { font-family: var(--font-heading); font-size: 1.5rem; color: var(--safety-orange); text-decoration: none; letter-spacing: 0.02em; }
  .site-footer__contact a { font-size: 0.9rem; color: rgba(255,255,255,0.7); text-decoration: underline; }
  .site-footer__area { font-size: 0.875rem; color: rgba(255,255,255,0.5); line-height: 1.5; margin-top: 0.5rem; }
  .site-footer__base {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 1.5rem 0;
    max-width: 1200px;
    margin: 0 auto;
  }
  .site-footer__base p { font-size: 0.8rem; color: rgba(255,255,255,0.4); margin: 0; }
  @media (max-width: 768px) {
    .site-footer__inner { grid-template-columns: 1fr 1fr; }
    .site-footer__brand { grid-column: 1 / -1; }
    .site-footer__contact { grid-column: 1 / -1; }
  }
  @media (max-width: 480px) {
    .site-footer__inner { grid-template-columns: 1fr; }
  }
</style>
