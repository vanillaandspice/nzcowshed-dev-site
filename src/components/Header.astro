---
const navLinks = [
  { label: 'Grooving Services', href: '/concrete-grooving-services', hasSubmenu: true },
  { label: 'Our Work', href: '/our-work' },
  { label: 'Testimonials', href: '/testimonials' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const serviceLinks = [
  { label: 'Cowshed Grooving', href: '/concrete-grooving-services/cowshed-grooving' },
  { label: 'Yards', href: '/concrete-grooving-services/yards' },
  { label: 'Car Parks', href: '/concrete-grooving-services/car-parks' },
  { label: 'Boat Ramps', href: '/concrete-grooving-services/boat-ramps-marine-docks' },
];

const currentPath = Astro.url.pathname;

const isServicesActive = currentPath.startsWith('/concrete-grooving-services');
---

<header class="site-header" data-services-active={isServicesActive ? 'true' : 'false'}>
  <div class="site-header__inner">
    <a href="/" class="site-header__logo" aria-label="NZ Cowshed Groovers — Home">
      <div class="site-header__logo-text">
        <span class="site-header__logo-line1">NZ Cowshed</span>
        <span class="site-header__logo-line2">Groovers</span>
      </div>
      <img
        src="/assets/brand/cow-character.webp"
        alt=""
        aria-hidden="true"
        class="site-header__logo-cow"
        loading="eager"
        decoding="async"
        width="55"
        height="48"
      />
    </a>
    <nav class="site-nav" id="site-nav" aria-label="Main navigation">
      <ul class="site-nav__list">
        {navLinks.map(link => (
          <li class={link.hasSubmenu ? 'has-submenu' : ''}>
            <a
              href={link.href}
              class:list={[
                'site-nav__link',
                { 'site-nav__link--active': currentPath === link.href || (link.hasSubmenu && isServicesActive) },
              ]}
              data-submenu-trigger={link.hasSubmenu ? 'services' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
        {/* Mobile-only CTA inside the nav drawer */}
        <li class="site-nav__cta-item">
          <a href="/contact" class="site-nav__cta-btn">Get a Free Quote →</a>
        </li>
      </ul>
    </nav>
    <a href="/contact" class="site-header__cta" aria-label="Get a free quote">
      <span class="site-header__cta-text">Get a Quote</span>
    </a>
    <button class="site-header__toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="site-nav">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="services-subnav" id="services-subnav" class:list={{ 'services-subnav--open': isServicesActive }}>
    <div class="services-subnav__inner">
      {serviceLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'services-subnav__link',
            { 'services-subnav__link--active': currentPath === link.href || currentPath.startsWith(link.href + '/') },
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('.site-header') as HTMLElement | null;
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  const subnav = document.getElementById('services-subnav');

  const servicesPageActive = header?.dataset.servicesActive === 'true';

  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(open));
  });

  document.querySelectorAll('[data-submenu-trigger="services"]').forEach(el => {
    el.addEventListener('click', (e) => {
      if (window.innerWidth >= 769) {
        if (servicesPageActive) return;
        e.preventDefault();
        subnav?.classList.toggle('services-subnav--open');
      }
    });
  });

  document.querySelectorAll('.site-nav__link:not([data-submenu-trigger])').forEach(el => {
    el.addEventListener('click', () => {
      subnav?.classList.remove('services-subnav--open');
    });
  });

  // Scroll shadow
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        header?.classList.toggle('is-scrolled', window.scrollY > 60);
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });
</script>

<style>
  /* ── Keyframes ──────────────────────────────────────────────────────────── */
  @keyframes ctaShimmer {
    0%   { transform: translateX(-150%) skewX(-20deg); opacity: 0; }
    15%  { opacity: 1; }
    85%  { opacity: 1; }
    100% { transform: translateX(250%) skewX(-20deg); opacity: 0; }
  }

  @keyframes ctaPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(236,121,38,0),
                            0 4px 14px rgba(236,121,38,0.35); }
    50%       { box-shadow: 0 0 0 7px rgba(236,121,38,0),
                            0 6px 22px rgba(236,121,38,0.6); }
  }

  @keyframes ctaEntrance {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes navCTAEntrance {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Header shell ───────────────────────────────────────────────────────── */
  .site-header {
    background: var(--deep-purple);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    transition: box-shadow 0.3s ease;
  }
  .site-header.is-scrolled {
    box-shadow: 0 4px 28px rgba(0,0,0,0.55);
  }
  .site-header__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem var(--space-grid-margin);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    grid-template-areas: "logo cta nav";
    align-items: center;
    gap: 1.5rem;
  }

  /* ── Logo ───────────────────────────────────────────────────────────────── */
  .site-header__logo {
    grid-area: logo;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.875rem;
    line-height: 1;
    text-decoration: none;
    flex-shrink: 0;
  }
  .site-header__logo-text {
    display: flex;
    flex-direction: column;
  }
  .site-header__logo-line1 {
    font-family: var(--font-heading);
    color: var(--safety-orange);
    font-size: 1.2rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .site-header__logo-line2 {
    font-family: var(--font-heading);
    color: var(--concrete-white);
    font-size: 1.5rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .site-header__logo-cow {
    height: 48px;
    width: auto;
    filter: drop-shadow(0 3px 8px rgba(59,31,110,0.3));
  }

  /* ── Nav ────────────────────────────────────────────────────────────────── */
  .site-nav { grid-area: nav; display: flex; justify-content: flex-end; }
  .site-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
  }
  .site-nav__link {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255,255,255,0.85);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius);
    transition: color var(--duration-fast);
    display: block;
  }
  .site-nav__link:hover,
  .site-nav__link--active { color: var(--teal); }

  /* Mobile CTA inside nav drawer — hidden on desktop */
  .site-nav__cta-item { display: none; }

  /* ── Services subnav ────────────────────────────────────────────────────── */
  .services-subnav {
    background: rgba(0,0,0,0.25);
    border-top: 1px solid rgba(255,255,255,0.08);
    display: none;
  }
  .services-subnav--open { display: block; }
  .services-subnav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.5rem var(--space-grid-margin);
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }
  .services-subnav__link {
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255,255,255,0.7);
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius);
    transition: color var(--duration-fast), background var(--duration-fast);
  }
  .services-subnav__link:hover { color: var(--concrete-white); background: rgba(255,255,255,0.08); }
  .services-subnav__link--active { color: var(--teal); }

  /* ── Get a Quote CTA ────────────────────────────────────────────────────── */
  .site-header__cta {
    grid-area: cta;
    justify-self: center;
    position: relative;
    font-family: var(--font-heading);
    font-size: 1.125rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    background: var(--safety-orange);
    color: var(--concrete-white);
    padding: 0.55rem 1.5rem;
    border-radius: var(--radius);
    white-space: nowrap;
    flex-shrink: 0;
    overflow: hidden;
    /* entrance */
    animation: ctaEntrance 0.5s var(--easing-standard) 0.3s both,
               ctaPulse 3.5s ease-in-out 2s infinite;
    transition: transform var(--duration-base) var(--easing-standard),
                box-shadow var(--duration-base) var(--easing-standard),
                background var(--duration-base) var(--easing-standard);
  }
  /* Shimmer sweep via ::before */
  .site-header__cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255,255,255,0.45) 50%,
      transparent 70%
    );
    transform: translateX(-150%) skewX(-20deg);
    animation: ctaShimmer 3.5s ease-in-out 1.2s infinite;
    pointer-events: none;
  }
  .site-header__cta-text {
    position: relative;
    z-index: 1;
  }
  .site-header__cta:hover {
    background: #f08030;
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 8px 28px rgba(236,121,38,0.65);
    animation: none; /* stop pulse on hover — hover state is emphatic enough */
  }
  .site-header__cta:hover::before {
    animation: ctaShimmer 0.7s ease-in-out; /* one fast sweep on hover */
  }
  .site-header__cta:active {
    transform: translateY(0) scale(0.98);
    box-shadow: 0 2px 8px rgba(236,121,38,0.4);
  }

  /* ── Hamburger toggle ───────────────────────────────────────────────────── */
  .site-header__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-shrink: 0;
  }
  .site-header__toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--concrete-white);
    transition: transform 0.25s var(--easing-standard), opacity 0.25s ease;
    transform-origin: center;
  }
  .site-header__toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .site-header__toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .site-header__toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile ─────────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .site-header__inner {
      display: flex;
      justify-content: space-between;
      padding: 0.75rem var(--space-grid-margin);
      gap: 0.75rem;
    }
    .site-header__toggle { display: flex; }
    .site-header__logo-cow { display: none; }

    /* Compact CTA stays visible in the bar on mobile */
    .site-header__cta {
      font-size: 0.95rem;
      padding: 0.45rem 1rem;
      letter-spacing: 0.04em;
    }

    .site-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--deep-purple);
      padding: 0 var(--space-grid-margin);
      box-shadow: 0 6px 20px rgba(0,0,0,0.4);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s var(--easing-standard),
                  padding 0.35s var(--easing-standard);
      /* override grid placement */
      display: block;
      justify-content: unset;
    }
    .site-nav.is-open {
      max-height: 520px;
      padding: 1rem var(--space-grid-margin) 1.5rem;
    }
    .site-nav__list {
      flex-direction: column;
      gap: 0;
      justify-content: unset;
    }
    .site-nav__link {
      display: block;
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .services-subnav { display: none !important; }

    /* CTA at bottom of mobile nav drawer */
    .site-nav__cta-item {
      display: block;
      padding-top: 1.25rem;
      margin-top: 0.25rem;
    }
    .site-nav__cta-btn {
      display: block;
      text-align: center;
      font-family: var(--font-heading);
      font-size: 1.25rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-decoration: none;
      background: var(--safety-orange);
      color: var(--concrete-white);
      padding: 0.875rem 1.5rem;
      border-radius: var(--radius);
      position: relative;
      overflow: hidden;
      transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
      animation: ctaPulse 3.5s ease-in-out 0.5s infinite;
    }
    .site-nav__cta-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        105deg,
        transparent 30%,
        rgba(255,255,255,0.4) 50%,
        transparent 70%
      );
      transform: translateX(-150%) skewX(-20deg);
      animation: ctaShimmer 3.5s ease-in-out 1.5s infinite;
      pointer-events: none;
    }
    .site-nav__cta-btn:active {
      transform: scale(0.98);
      box-shadow: 0 2px 8px rgba(236,121,38,0.4);
    }

    /* Entrance animation for mobile drawer CTA */
    .site-nav.is-open .site-nav__cta-item {
      animation: navCTAEntrance 0.3s var(--easing-standard) 0.2s both;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__cta,
    .site-header__cta::before,
    .site-nav__cta-btn,
    .site-nav__cta-btn::before {
      animation: none;
    }
  }
</style>
