---
const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Our Work', href: '/our-work' },
  { label: 'Testimonials', href: '/testimonials' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__logo" aria-label="NZ Cowshed Groovers — Home">
      <img src="/assets/brand/banner-logo.webp" alt="NZ Cowshed Groovers" width="200" height="48" />
    </a>
    <nav class="site-nav" id="site-nav" aria-label="Main navigation">
      <ul class="site-nav__list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['site-nav__link', { 'site-nav__link--active': currentPath === link.href || currentPath.startsWith(link.href + '/') }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <a href="/contact" class="site-header__cta">Get a Quote</a>
    <button class="site-header__toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="site-nav">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>

<style>
  .site-header {
    background: var(--deep-purple);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .site-header__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.75rem var(--space-grid-margin);
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .site-header__logo img {
    height: 48px;
    width: auto;
    display: block;
  }
  .site-nav { flex: 1; }
  .site-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }
  .site-nav__link {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255,255,255,0.85);
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius);
    transition: color var(--duration-fast);
  }
  .site-nav__link:hover,
  .site-nav__link--active { color: var(--teal); }
  .site-header__cta {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    background: var(--safety-orange);
    color: var(--concrete-white);
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .site-header__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-shrink: 0;
  }
  .site-header__toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--concrete-white);
  }
  @media (max-width: 768px) {
    .site-header__toggle { display: flex; }
    .site-header__cta { display: none; }
    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--primary);
      padding: 1rem var(--space-grid-margin);
    }
    .site-nav.is-open { display: block; }
    .site-nav__list { flex-direction: column; gap: 0; }
    .site-nav__link { display: block; padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.1); }
  }
</style>
