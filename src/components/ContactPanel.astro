---
import Section from './Section.astro';
import EnquiryForm from './EnquiryForm';
---

<Section bg="deep-purple" narrow>
  <div class="cp-call">
    <div class="cp-call__text">
      <p class="cp-call__label">Talk to Scott directly</p>
      <a href="tel:+6427474775" class="cp-call__number">0274 747 775</a>
      <p class="cp-call__sub">Mon–Fri, during farming hours. He'll pick up.</p>
    </div>
    <a href="tel:+6427474775" class="cp-call__btn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.63 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.84a16 16 0 0 0 6.29 6.29l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      Call now
    </a>
  </div>
  <div class="cp-divider">
    <span>or fill in the form below</span>
  </div>
</Section>

<Section bg="concrete-white" narrow>
  <EnquiryForm client:load />
</Section>

<style>
  .cp-call {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .cp-call__text {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .cp-call__label {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal);
    margin: 0;
  }
  .cp-call__number {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    color: var(--concrete-white);
    text-decoration: none;
    letter-spacing: 0.02em;
    line-height: 1;
    transition: color 0.2s ease;
  }
  .cp-call__number:hover { color: var(--teal); }
  .cp-call__sub {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: rgba(255,255,255,0.6);
    margin: 0;
    font-style: italic;
  }
  .cp-call__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--safety-orange);
    color: var(--concrete-white);
    font-family: var(--font-heading);
    font-size: 1.125rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.9rem 1.75rem;
    border-radius: var(--radius);
    white-space: nowrap;
    transition: background 0.2s ease, transform 0.15s ease;
    flex-shrink: 0;
  }
  .cp-call__btn:hover {
    background: #d4530e;
    transform: translateY(-2px);
  }
  .cp-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    color: rgba(255,255,255,0.35);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-style: italic;
  }
  .cp-divider::before,
  .cp-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.2);
  }
  @media (max-width: 600px) {
    .cp-call {
      flex-direction: column;
      align-items: flex-start;
    }
    .cp-call__btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
