---
import Section from './Section.astro';
import EnquiryForm from './EnquiryForm';
---

<Section bg="deep-purple" narrow>
  <div class="cp-header">
    <p class="cp-header__label">Get a quote</p>
    <h2 class="cp-header__heading">Fill in the enquiry form</h2>
    <p class="cp-header__sub">We'll get back to you once the machines are off. Or if you prefer, you can call Scott on <a href="tel:+6427474775" class="cp-header__phone">0274 747 775</a> — leave a message if he doesn't pick up.</p>
  </div>
</Section>

<Section bg="concrete-white" narrow>
  <EnquiryForm client:load />
</Section>

<style>
  .cp-header {
    text-align: center;
    max-width: 56ch;
    margin: 0 auto;
  }
  .cp-header__label {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal);
    margin: 0 0 0.5rem;
  }
  .cp-header__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--concrete-white);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0 0 1rem;
  }
  .cp-header__sub {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.75);
    margin: 0;
  }
  .cp-header__phone {
    color: var(--safety-orange);
    text-decoration: none;
    font-weight: 600;
  }
  .cp-header__phone:hover { text-decoration: underline; }
</style>
