---
---
<div class="groove-divider" aria-hidden="true">
  <svg viewBox="0 0 1200 32" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    {Array.from({ length: 24 }, (_, i) => (
      <rect x={i * 50} y="12" width="3" height="8" fill="var(--teal)" opacity="0.6">
        <animate
          attributeName="opacity"
          values="0.6;1;0.6"
          dur="2.4s"
          begin={`${i * 0.08}s`}
          repeatCount="indefinite"
        />
      </rect>
    ))}
    {Array.from({ length: 24 }, (_, i) => (
      <rect x={i * 50 + 12} y="8" width="3" height="16" fill="var(--deep-purple)" opacity="0.4">
        <animate
          attributeName="opacity"
          values="0.4;0.75;0.4"
          dur="2.4s"
          begin={`${i * 0.08 + 0.04}s`}
          repeatCount="indefinite"
        />
      </rect>
    ))}
    {Array.from({ length: 24 }, (_, i) => (
      <rect x={i * 50 + 24} y="12" width="3" height="8" fill="var(--teal)" opacity="0.6">
        <animate
          attributeName="opacity"
          values="0.6;1;0.6"
          dur="2.4s"
          begin={`${i * 0.08 + 0.08}s`}
          repeatCount="indefinite"
        />
      </rect>
    ))}
  </svg>
</div>

<style>
  .groove-divider {
    width: 100%;
    max-width: 100%;
    background: var(--surface-container-high);
    overflow: hidden;
  }
  .groove-divider svg {
    width: 100%;
    max-width: 100%;
    height: 32px;
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    .groove-divider svg * { animation: none !important; }
  }
</style>
