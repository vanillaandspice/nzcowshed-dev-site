---
interface Slide {
  photo: string;
  title: string;
  caption: string;
}
interface Props {
  slides: Slide[];
}
const { slides } = Astro.props;
---

<div class="carousel" aria-label="Work gallery">
  <div class="carousel__viewport">
    <div class="carousel__track" id="carousel-track">
      {slides.map((slide, i) => (
        <div class="carousel__item" role="group" aria-label={`Slide ${i + 1} of ${slides.length}`}>
          <div class="carousel__img-wrap">
            <img
              src={slide.photo}
              alt={slide.title}
              loading={i < 3 ? "eager" : "lazy"}
              decoding="async"
            />
          </div>
          <div class="carousel__caption">
            <h3 class="carousel__title">{slide.title}</h3>
            <p class="carousel__text">{slide.caption}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="carousel__controls">
    <button class="carousel__btn carousel__btn--prev" id="carousel-prev" aria-label="Previous slides">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="carousel__dots" id="carousel-dots" aria-hidden="true"></div>

    <button class="carousel__btn carousel__btn--next" id="carousel-next" aria-label="Next slides">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</div>

<style>
  .carousel {
    width: 100%;
  }

  .carousel__viewport {
    overflow: hidden;
    border-radius: var(--radius-lg, 8px);
  }

  .carousel__track {
    display: flex;
    gap: 1.25rem;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .carousel__item {
    flex: 0 0 calc((100% - 2 * 1.25rem) / 3);
    min-width: 0;
    display: flex;
    flex-direction: column;
    background: var(--concrete-white, #fff);
    border-top: 3px solid var(--teal, #2ec4b6);
    border-radius: 0 0 var(--radius, 4px) var(--radius, 4px);
    overflow: hidden;
  }

  .carousel__img-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #111;
  }

  .carousel__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .carousel__item:hover .carousel__img-wrap img {
    transform: scale(1.04);
  }

  .carousel__caption {
    padding: 1rem 1.125rem 1.25rem;
    flex: 1;
  }

  .carousel__title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--deep-purple);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .carousel__text {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--on-surface-variant, #555);
    margin: 0;
    line-height: 1.55;
  }

  /* Controls */
  .carousel__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .carousel__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--teal, #2ec4b6);
    background: transparent;
    color: var(--teal, #2ec4b6);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, transform 0.15s ease;
    flex-shrink: 0;
  }

  .carousel__btn:hover {
    background: var(--teal, #2ec4b6);
    color: var(--concrete-white, #fff);
    transform: scale(1.08);
  }

  .carousel__btn:disabled {
    opacity: 0.35;
    cursor: default;
    transform: none;
  }

  .carousel__dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .carousel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(0,0,0,0.2);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .carousel__dot.is-active {
    background: var(--teal, #2ec4b6);
    transform: scale(1.35);
  }

  /* Tablet: show 2 */
  @media (max-width: 900px) {
    .carousel__item {
      flex: 0 0 calc((100% - 1.25rem) / 2);
    }
  }

  /* Mobile: show 1 */
  @media (max-width: 560px) {
    .carousel__item {
      flex: 0 0 100%;
    }
    .carousel__viewport {
      border-radius: var(--radius, 4px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel__track { transition: none; }
    .carousel__img-wrap img { transition: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".carousel").forEach(carousel => {
    const track = carousel.querySelector<HTMLElement>("#carousel-track");
    const prevBtn = carousel.querySelector<HTMLButtonElement>("#carousel-prev");
    const nextBtn = carousel.querySelector<HTMLButtonElement>("#carousel-next");
    const dotsContainer = carousel.querySelector<HTMLElement>("#carousel-dots");

    if (!track) return;

    const items = Array.from(track.querySelectorAll<HTMLElement>(".carousel__item"));
    let currentIndex = 0;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function getVisible(): number {
      const vw = window.innerWidth;
      if (vw <= 560) return 1;
      if (vw <= 900) return 2;
      return 3;
    }

    function totalSteps(): number {
      return Math.max(0, items.length - getVisible());
    }

    // Build dots
    function buildDots() {
      if (!dotsContainer) return;
      dotsContainer.innerHTML = "";
      const steps = totalSteps();
      for (let i = 0; i <= steps; i++) {
        const dot = document.createElement("button");
        dot.className = "carousel__dot" + (i === currentIndex ? " is-active" : "");
        dot.setAttribute("aria-label", `Go to position ${i + 1}`);
        dot.addEventListener("click", () => { stop(); goTo(i); start(); });
        dotsContainer.appendChild(dot);
      }
    }

    function updateDots() {
      dotsContainer?.querySelectorAll(".carousel__dot").forEach((dot, i) => {
        dot.classList.toggle("is-active", i === currentIndex);
      });
    }

    function updateButtons() {
      if (prevBtn) prevBtn.disabled = currentIndex === 0;
      if (nextBtn) nextBtn.disabled = currentIndex >= totalSteps();
    }

    function goTo(index: number) {
      const steps = totalSteps();
      currentIndex = Math.max(0, Math.min(index, steps));
      const visible = getVisible();
      const itemWidth = items[0]?.offsetWidth ?? 0;
      const gap = 20; // 1.25rem in px
      track.style.transform = `translateX(${-(currentIndex * (itemWidth + gap))}px)`;
      updateDots();
      updateButtons();
    }

    function start() {
      if (items.length <= getVisible()) return;
      autoTimer = setInterval(() => {
        if (currentIndex >= totalSteps()) {
          goTo(0);
        } else {
          goTo(currentIndex + 1);
        }
      }, 4500);
    }

    function stop() {
      if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
    }

    prevBtn?.addEventListener("click", () => { stop(); goTo(currentIndex - 1); start(); });
    nextBtn?.addEventListener("click", () => { stop(); goTo(currentIndex + 1); start(); });

    carousel.addEventListener("mouseenter", stop);
    carousel.addEventListener("mouseleave", start);

    // Touch / swipe support
    let touchStartX = 0;
    carousel.addEventListener("touchstart", (e: TouchEvent) => { touchStartX = e.touches[0].clientX; stop(); }, { passive: true });
    carousel.addEventListener("touchend", (e: TouchEvent) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(currentIndex + (diff > 0 ? 1 : -1));
      start();
    });

    // Recalc on resize
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        buildDots();
        goTo(Math.min(currentIndex, totalSteps()));
      }, 150);
    });

    // Init
    buildDots();
    goTo(0);
    start();
  });
</script>
