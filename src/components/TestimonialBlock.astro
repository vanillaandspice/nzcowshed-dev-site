---
interface Props {
  quote: string;
  attribution: string;
  business?: string;
}
const { quote, attribution, business } = Astro.props;
---
<blockquote class="testimonial">
  <p class="testimonial__quote">"{quote}"</p>
  <cite class="testimonial__attribution">
    <strong>{attribution}</strong>
    {business && <span class="testimonial__biz"> — {business}</span>}
  </cite>
</blockquote>

<style>
  .testimonial { margin: 0; }
  .testimonial__quote {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.125rem;
    line-height: var(--leading-body-lg);
    margin: 0 0 0.75rem;
  }
  .testimonial__attribution {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-style: normal;
    color: var(--teal);
    display: block;
  }
  .testimonial__biz {
    color: var(--on-surface-variant);
    font-weight: 400;
  }
</style>
