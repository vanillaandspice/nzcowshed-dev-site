---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import ZoomModal from '../components/ZoomModal';

const siteUrl = 'https://www.nzcowshedgroovers.co.nz';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${siteUrl}/about` },
  ],
};
---

<Layout
  title="About NZ Cowshed Groovers — Scott Coker, Concrete Grooving Specialist"
  description="NZ Cowshed Groovers was founded by Neil Taylor, who developed the concrete grooving technique. Now operated by Scott Coker. 100% lifetime guarantee on every groove."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <section style="background: var(--deep-purple); padding: var(--space-section) var(--space-grid-margin);">
    <div class="about-hero">
      <div class="about-hero__img" style="background: #000 center/cover url('/assets/brand/truck-scott.webp'); aspect-ratio: 4/3; border-radius: var(--radius);"></div>
      <div class="about-hero__text">
        <p style="font-family: var(--font-heading); font-size: 1.125rem; letter-spacing: 0.05em; color: var(--teal); text-transform: uppercase; margin: 0 0 0.75rem;">About</p>
        <h1 style="color: var(--concrete-white); margin: 0 0 1rem;">The original NZ groover</h1>
        <p style="font-family: var(--font-body); font-size: 1.25rem; line-height: 1.6; color: rgba(255,255,255,0.9); margin: 0;">
          Combining Kiwi ingenuity, concrete cutting experience, and engineering talent, Neil Taylor built the original grooving machines which have been keeping cows safe on New Zealand farms for decades.
        </p>
      </div>
    </div>
  </section>

  <style>
    .about-hero {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: var(--space-stack-lg);
      align-items: center;
    }
    @media (max-width: 768px) {
      .about-hero {
        grid-template-columns: 1fr;
      }
      .about-hero__img {
        order: -1;
      }
    }
  </style>

  <Section bg="concrete-white" narrow>
    <h2 style="font-family: var(--font-heading); font-size: 2rem; color: var(--deep-purple); text-transform: uppercase; letter-spacing: 0.02em; margin: 0 0 1rem;">The history</h2>
    <p style="font-family: var(--font-body); font-size: 1.125rem; line-height: 1.6; margin: 0 0 1rem;">
      NZ Cowshed Groovers was founded by <strong>Neil Taylor</strong>. He used his engineering skills to design the grooving technique and build the custom machines we still use today. Dairy farmers all over New Zealand know Neil and trust his work.
    </p>
    <p style="font-family: var(--font-body); font-size: 1.125rem; line-height: 1.6; margin: 0 0 1rem;">
      <strong>Scott Coker</strong> is taking over the business now. Scott is married to Neil's daughter, Sarsha, keeping the business in the family. Scott has over twenty years of experience running fabrication and welding, and local businesses.
    </p>
    <p style="font-family: var(--font-body); font-size: 1.125rem; line-height: 1.6; margin: 0;">
      Neil's wet-saw method and lifetime guarantee will never change. To make things easy, you can now enquire through our website at any time. Scott is out operating the machinery during the day, so if he misses a call, leave a message and he'll get back to you once the machines are turned off.
    </p>
  </Section>

  <Section bg="safety-orange" narrow>
    <p style="font-family: var(--font-heading); font-size: 1.125rem; letter-spacing: 0.05em; color: var(--concrete-white); text-transform: uppercase; margin: 0 0 0.5rem;">100% lifetime guarantee</p>
    <p style="font-family: var(--font-body); font-size: 1.25rem; line-height: 1.6; color: var(--concrete-white); margin: 0;">
      When you invest in concrete grooving, you need to know it is money well spent. Our wet-saw method cuts deep, permanent grooves that are built to last. Nothing should ever go wrong with the cut itself. As Neil says, "I've never had a comeback in over 20 years." We stand behind that record completely. We guarantee the quality of our work, and if there is ever an issue with our grooves, we will come back and make it right at no charge.
    </p>
  </Section>

  <Section bg="surface">
    <h3 style="font-family: var(--font-heading); font-size: 1.5rem; color: var(--deep-purple); text-transform: uppercase; letter-spacing: 0.02em; margin: 0 0 1rem;">How we work</h3>
    <ul style="list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 0.75rem;">
      {[
        'Wet-saw diamond blade — proprietary technique developed by Neil Taylor',
        'Custom built machinery — built for NZ farm conditions',
        '100% lifetime guarantee on every groove',
        'North Island focus — nationwide capability',
        'Single-operator + casual crew — direct line to Scott on every job',
      ].map(line => (
        <li style="font-family: var(--font-body); font-size: 1.125rem; line-height: 1.5; padding-left: 1.25rem; border-left: 3px solid var(--teal);">
          {line}
        </li>
      ))}
    </ul>
  </Section>

  <Section bg="surface">
    <figure style="margin: 0; max-width: 680px; margin-inline: auto;">
      <ZoomModal
        client:load
        src="/assets/brand/neil-clipping.webp"
        alt="Neil Taylor working on the Waikato Student Union, long before he set up NZ Cowshed Groovers."
      />
      <figcaption style="font-family: var(--font-body); font-size: 0.875rem; line-height: 1.4; color: var(--on-surface-variant); margin: 0.75rem 0 0; font-style: italic; text-align: center;">
        Neil Taylor working on the Waikato Student Union, long before he set up NZ Cowshed Groovers.
      </figcaption>
    </figure>
  </Section>
</Layout>
