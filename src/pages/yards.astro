---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import TestimonialBlock from '../components/TestimonialBlock.astro';
import ServiceHero from '../components/ServiceHero.astro';
import Slideshow from '../components/Slideshow.astro';

const slides = [
  { photo: '/assets/photos/yard-grooved.webp', line1: '15,000 cattle through this yard', line2: 'Not a single problem since grooving', name: 'Gordon Wright', location: 'Waikato' },
  { photo: '/assets/photos/frankton-sale-yards.webp', line1: '186 m² of sale yard grooved', line2: 'Drafting drift completely eliminated', name: 'John', location: 'Frankton Sale Yards, Hamilton' },
  { photo: '/assets/photos/livestock-improvements.webp', line1: 'Cows no longer slip in the yard', line2: 'Much easier to draft and handle', name: 'Graham & Odele Wells', location: 'Dairy Farmers' },
];
---

<Layout
  title="Yard Grooving NZ — Non-Slip Cattle Yards & Drafting Yards"
  description="Concrete grooving for drafting yards, loading yards, sale yards and feedpads. Stop stock slipping — grooved yards mean safer handling and faster throughput. NZ Cowshed Groovers."
>
  <ServiceHero
    breadcrumb="Services / Yards"
    headline="Yards that grip"
    lead="Concrete grooving is the fastest, safest & most efficient way to turn your existing concrete into a long lasting non-slip surface."
    photo="/assets/photos/yard-grooved.webp"
    photoAlt="Grooved cattle yard"
    ctaLabel="Free Quote"
  />

  <Section bg="concrete-white" narrow>
    <h2 style="font-family: var(--font-heading); font-size: 2rem; color: var(--deep-purple); text-transform: uppercase; letter-spacing: 0.02em; margin: 0 0 1rem;">
      What we groove
    </h2>
    <ul style="list-style: none; padding: 0; margin: 0 0 2rem; display: flex; flex-direction: column; gap: 0.75rem;">
      {[
        'Drafting yards — easier handling, less stress on stock',
        'Loading yards — cows stay on their feet up the ramp',
        'Sale yards — proven in commercial multi-truck environments',
        'Feedpads, underpasses, races — anywhere concrete gets wet',
      ].map(line => (
        <li style="font-family: var(--font-body); font-size: 1.125rem; line-height: 1.5; padding-left: 1.5rem; position: relative;">
          <span style="position: absolute; left: 0; color: var(--teal); font-weight: 700;">—</span> {line}
        </li>
      ))}
    </ul>
  </Section>

  <Section bg="surface" narrow>
    <Card>
      <TestimonialBlock
        quote="Cows were slipping when going through yards. Very pleased — prevented the cows from slipping over. It has been a 100% improvement."
        attribution="John"
        business="Frankton Sale Yards, Hamilton"
      />
    </Card>
  </Section>

  <Section bg="surface">
    <h2 style="font-family: var(--font-heading); font-size: 2rem; color: var(--deep-purple); text-transform: uppercase; letter-spacing: 0.02em; margin: 0 0 1.5rem; text-align: center;">
      Jobs we've done
    </h2>
    <Slideshow slides={slides} />
  </Section>

  <Section bg="safety-orange" narrow>
    <div style="text-align: center;">
      <Button variant="ghost" href="/contact">Free Quote</Button>
    </div>
  </Section>
</Layout>
