---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import EnquiryForm from '../components/EnquiryForm';
---

<Layout
  title="Get a Quote — Contact NZ Cowshed Groovers"
  description="Contact NZ Cowshed Groovers for a concrete grooving quote. Call Scott on 0274 747 775 or fill in the form. North Island specialists, nationwide capability."
>
  <Section bg="deep-purple" narrow>
    <div style="text-align: center;">
      <img
        src="/assets/brand/cow-character.webp"
        alt=""
        aria-hidden="true"
        style="display: block; width: clamp(160px, 18vw, 240px); height: auto; margin: 0 auto 1.5rem; filter: drop-shadow(0 8px 20px rgba(0,0,0,0.35));"
        loading="eager"
        decoding="async"
      />
      <h1 style="color: var(--concrete-white); margin: 0 0 1rem;">Get in touch</h1>
      <p style="font-family: var(--font-body); font-size: 1.25rem; color: rgba(255,255,255,0.9); line-height: 1.6; margin: 0;">
        Fill in the form below,<br />
        or call Scott on:<br />
        <strong><a href="tel:+6427474775" style="color: var(--safety-orange); text-decoration: none;">0274 747 775</a></strong>
      </p>
      <p style="font-family: var(--font-body); font-size: 0.95rem; color: rgba(255,255,255,0.55); font-style: italic; margin: 0.75rem 0 0;">Mon–Fri, during farming hours. He'll pick up.</p>
    </div>
  </Section>

  <Section bg="surface">
    <div class="contact-grid">
      <div class="contact-sidebar">
        <p class="contact-sidebar__label">or call Scott on:</p>
        <a href="tel:+6427474775" class="contact-sidebar__phone">0274 747 775</a>
        <p class="contact-sidebar__hours">Mon–Fri, during farming hours. He'll pick up.</p>

        <h4 class="contact-sidebar__heading">Email</h4>
        <a href="mailto:info@cowshedgroovers.co.nz" class="contact-sidebar__email">info@cowshedgroovers.co.nz</a>

        <h4 class="contact-sidebar__heading">Service area</h4>
        <p class="contact-sidebar__body">North Island, New Zealand — nationwide capability. We come to your farm.</p>

        <h4 class="contact-sidebar__heading">Pricing</h4>
        <p class="contact-sidebar__body">
          <span style="color: var(--safety-orange);">Setup fee</span> plus per m² rate depending on access &amp; condition.<br /><br />
          <strong>100% lifetime guarantee included.</strong>
        </p>
      </div>
      <EnquiryForm client:load />
    </div>
  </Section>
</Layout>

<style>
  .contact-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-stack-lg);
    align-items: start;
  }

  /* ── Sidebar ───────────────────────────────────────────── */
  .contact-sidebar__label {
    font-family: var(--font-heading);
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--deep-purple);
    margin: 0 0 0.375rem;
  }
  .contact-sidebar__phone {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    color: var(--safety-orange);
    text-decoration: none;
    letter-spacing: 0.02em;
    display: block;
    margin: 0 0 1.75rem;
    line-height: 1.1;
    transition: color 0.18s ease;
  }
  .contact-sidebar__phone:hover { color: #f87d3a; }
  .contact-sidebar__heading {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--teal);
    margin: 0 0 0.3rem;
  }
  .contact-sidebar__email {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text-main);
    text-decoration: underline;
    text-underline-offset: 3px;
    display: block;
    margin: 0 0 1.25rem;
    transition: color 0.18s ease;
  }
  .contact-sidebar__email:hover { color: var(--teal); }
  .contact-sidebar__hours {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--on-surface-variant);
    font-style: italic;
    margin: 0 0 1.5rem;
  }
  .contact-sidebar__body {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 1.25rem;
    color: var(--text-main);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .contact-sidebar {
      order: 2;
    }
  }
</style>
